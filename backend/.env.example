# -----------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# -----------------------------------------------------------------------

# Databricks connection
DATABRICKS_SERVER_HOSTNAME=adb-xxxxxxxxxxxx.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx
ANALYTICS_INPUT_PATH=your_catalog.your_schema

# JWT secrets — generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
REFRESH_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32_different_value

# JWT algorithm (keep HS256 unless you switch to RS256)
ALGORITHM=HS256

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Brute-force protection
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# Result cache for Databricks analytics
# CACHE_ENABLED=false disables it entirely; TTL is in seconds (600 = 10 min)
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=3600
# Backend: "memory" (per-process) or "redis" (shared across instances).
# For a multi-instance deployment use redis so all instances share the cache.
CACHE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
