# ─────────────────────────────────────────────────────────────────────────────
# MonCash BI Portal — Deployment env template
# Copy to `.env` at the repo root before running `docker compose up`.
# Never commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Databricks SQL warehouse ─────────────────────────────────────────────────
DATABRICKS_SERVER_HOSTNAME=adb-xxxxxxxxxxxx.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx
ANALYTICS_INPUT_PATH=gr_dgc_dwh_prd.ods_dl

# ── Azure Service Principal (headless Databricks auth) ──────────────────────
# Create an app registration in Azure AD, grant it the Databricks
# `user_impersonation` API permission, and paste the credentials here.
# On an Azure-hosted VM with Managed Identity you can leave these empty.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── JWT signing keys — MUST be random, long, and unique ──────────────────────
# Generate strong keys locally with:  openssl rand -hex 64
SECRET_KEY=REPLACE_WITH_openssl_rand_-hex_64
REFRESH_SECRET_KEY=REPLACE_WITH_openssl_rand_-hex_64
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
# The frontend and backend share an origin thanks to nginx, so in the standard
# deployment you only need the public URL of the portal itself.
# Comma-separated list; include https:// URLs once you have a certificate.
# Digicel production example:
#   http://ht-moncashreporting,http://172.20.197.246
CORS_ORIGINS=https://ht-moncashreporting.digicelgroup.local,https://your-server-ip,http://localhost

# ── Trusted hosts (Host header allow-list) ───────────────────────────────────
# FastAPI's TrustedHostMiddleware rejects requests whose Host header is not
# in this list. Leave empty to accept any host (matches nginx behavior).
# In production, set to your server's hostname + IP + localhost.
# Digicel production example:
#   ht-moncashreporting,172.20.197.246,localhost
ALLOWED_HOSTS=

# ── Reverse-proxy prefix ─────────────────────────────────────────────────────
# nginx serves the backend at /api/* — set ROOT_PATH=/api so Swagger UI at
# http://<server>/api/docs can load the OpenAPI schema + fire "Try it out"
# requests through the same prefix. Leave empty when running the backend
# directly without a reverse proxy.
ROOT_PATH=/api

# ── Cache TTL (seconds) ──────────────────────────────────────────────────────
# Databricks data is J-1 (yesterday's ETL), so cache aggressively and rely on
# a scheduled Redis FLUSHDB at 1 AM Haiti time (see the cron entry documented
# in GUIDE_DEPLOIEMENT_IT.md §12.8) to refresh everything once per day.
#
# 90000 = 25 hours — long enough to survive between daily flushes, short
# enough to auto-purge if the cron ever misses a run.
#
# Set to 600 (10 min) if you don't run the daily cron flush.
CACHE_DEFAULT_TTL=90000

# ── Runtime tuning ───────────────────────────────────────────────────────────
# Uvicorn worker count for the backend container. Rule of thumb: 2×CPU + 1.
UVICORN_WORKERS=2

# Host port to expose the frontend on. Default 80. Use 8080 in dev if 80 is busy.
WEB_PORT=80

# Host port for the HTTPS frontend. Default 443. Change if 443 is already used
# on the host (rare) or if you're routing TLS termination elsewhere.
WEB_PORT_HTTPS=443

# Host directory containing the TLS certificate + private key. Mounted into
# the frontend nginx container as read-only at /etc/nginx/ssl.
# Required files inside this directory:
#   moncash-bi.crt   — signed certificate (PEM)
#   moncash-bi.key   — private key (PEM, chmod 600)
SSL_CERT_DIR=/etc/ssl/moncash-bi


# uvicorn main:app --reload --host 0.0.0.0 --port 8000
